# AI Model — Vertex AI (Gemini). Project must have Vertex AI API enabled.
# Auth via Application Default Credentials: `gcloud auth application-default login`
# or set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON path.
AI_MODEL=vertex/gemini-2.5-flash
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=asia-southeast1
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa.json

# Supabase
SUPABASE_URL=https://example.supabase.co
SUPABASE_SECRET_KEY=your_secret_key_here

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_APP_SECRET=your_app_secret_here

# Visible WhatsApp business phone number used in wa.me deep links.
# E.164 format WITHOUT the leading '+' (e.g. 60123456789 for Malaysia).
# Distinct from WHATSAPP_PHONE_NUMBER_ID which is Meta's internal phone ID.
WHATSAPP_BUSINESS_PHONE=60123456789

# PostgreSQL
POSTGRES_URL=postgresql://user:password@localhost:5432/anyhealth_bot

# Required for /api/cron/reminders. Set a strong random value; matches Vercel Cron header.
CRON_SECRET=

# --- Food-photo nutrition logging ---
# gemini = vision LLM (Vertex via AI_MODEL above) returns identification + macros in one call.
# edamam = vision identifies, Edamam API enriches; per-item fallback to vision macros on failure.
NUTRITION_PROVIDER=gemini
EDAMAM_APP_ID=                  # required only if NUTRITION_PROVIDER=edamam
EDAMAM_APP_KEY=                 # required only if NUTRITION_PROVIDER=edamam

# --- AnyHealth Elysia API (fullstack) ---
# All bot tools talk to the API via these creds; no direct Supabase access.
ANYHEALTH_API_URL=http://localhost:3000
ANYHEALTH_BOT_API_KEY=ah_test_bot_sandbox

# Internal token for /api/clinic/notifications/sweep (cron only).
NOTIFICATIONS_SWEEP_TOKEN=
